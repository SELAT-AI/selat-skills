{
  "schema": "selat-skill/v1",
  "name": "comprehensive-enrichment",
  "description": "Comprehensive person + company enrichment across many MPP-routed data providers (Apollo, Hunter, Clado, Abstract Company Enrichment, Diffbot KG, Exa, Firecrawl). Resolves contact info, verified emails, phone, social profiles, company overview, funding, products, and competitors. All steps are routed through the SELAT Router (MPP).",
  "maxAmount": "1.00",
  "params": {
    "email": {
      "required": false,
      "default": "test@stripe.com",
      "description": "Person work email, e.g. john@stripe.com. Drives person enrichment and email-based lookups."
    },
    "firstName": {
      "required": false,
      "default": "John",
      "description": "Person first name, e.g. John."
    },
    "lastName": {
      "required": false,
      "default": "Doe",
      "description": "Person last name, e.g. Doe."
    },
    "company": {
      "required": false,
      "default": "Stripe",
      "description": "Company name, e.g. Stripe."
    },
    "domain": {
      "required": false,
      "default": "stripe.com",
      "description": "Company domain, e.g. stripe.com. Drives company enrichment and domain-based email lookups."
    },
    "linkedinUrl": {
      "required": false,
      "default": "https://linkedin.com/in/williamhgates",
      "description": "LinkedIn person profile URL, e.g. https://linkedin.com/in/johndoe. Required for the phone lookup step (Clado contacts)."
    },
    "pricingUrl": {
      "required": false,
      "default": "",
      "description": "A company page to scrape for products/pricing, e.g. https://stripe.com/pricing."
    }
  },
  "steps": [
    {
      "label": "person deep search — Clado search (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://clado.mpp.paywithlocus.com/clado/search",
      "body": {
        "query": "${firstName} ${lastName} ${company}"
      },
      "maxAmount": "1.00"
    },
    {
      "label": "person enrichment — Apollo people-enrichment (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://apollo.mpp.paywithlocus.com/apollo/people-enrichment",
      "body": {
        "first_name": "${firstName}",
        "last_name": "${lastName}",
        "organization_name": "${company}",
        "linkedin_url": "${linkedinUrl}"
      },
      "maxAmount": "0.10"
    },
    {
      "label": "email enrich — Hunter email-enrichment (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://hunter.mpp.paywithlocus.com/hunter/email-enrichment",
      "body": {
        "email": "${email}"
      },
      "maxAmount": "0.15"
    },
    {
      "label": "find work email — Hunter email-finder",
      "rail": "routed",
      "method": "POST",
      "url": "https://hunter.mpp.paywithlocus.com/hunter/email-finder",
      "body": {
        "domain": "${domain}",
        "first_name": "${firstName}",
        "last_name": "${lastName}"
      },
      "maxAmount": "0.15"
    },
    {
      "label": "verify email — Hunter email-verifier",
      "rail": "routed",
      "method": "POST",
      "url": "https://hunter.mpp.paywithlocus.com/hunter/email-verifier",
      "body": {
        "email": "${email}"
      },
      "maxAmount": "0.10"
    },
    {
      "label": "phone — Clado contacts (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://clado.mpp.paywithlocus.com/clado/contacts",
      "body": {
        "linkedin_url": "${linkedinUrl}"
      },
      "maxAmount": "0.50"
    },
    {
      "label": "person research — Exa search (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://exa.mpp.tempo.xyz/search",
      "body": {
        "query": "${firstName} ${lastName} ${company} recent news interviews talks"
      },
      "maxAmount": "0.10"
    },
    {
      "label": "company overview — Abstract Company Enrichment lookup (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://abstract-company-enrichment.mpp.paywithlocus.com/abstract-company-enrichment/lookup",
      "body": {
        "domain": "${domain}"
      },
      "maxAmount": "0.10"
    },
    {
      "label": "company emails — Hunter domain-search",
      "rail": "routed",
      "method": "POST",
      "url": "https://hunter.mpp.paywithlocus.com/hunter/domain-search",
      "body": {
        "domain": "${domain}"
      },
      "maxAmount": "1.00"
    },
    {
      "label": "funding + investors — Diffbot KG enhance (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://diffbot-kg.mpp.paywithlocus.com/diffbot-kg/enhance",
      "body": {
        "type": "Organization",
        "name": "${company}"
      },
      "maxAmount": "0.40"
    },
    {
      "label": "pricing/features — Firecrawl extract (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://firecrawl.mpp.tempo.xyz/v1/extract",
      "body": {
        "urls": [
          "${pricingUrl}"
        ],
        "prompt": "Extract all products, pricing tiers, and features"
      },
      "maxAmount": "0.10"
    },
    {
      "label": "competitors — Exa findSimilar",
      "rail": "routed",
      "method": "POST",
      "url": "https://exa.mpp.tempo.xyz/findSimilar",
      "body": {
        "url": "https://${domain}",
        "numResults": 10,
        "contents": {
          "text": true
        }
      },
      "maxAmount": "0.10"
    },
    {
      "label": "company research — Exa search (MPP, ROUTED via SELAT Router)",
      "rail": "routed",
      "method": "POST",
      "url": "https://exa.mpp.tempo.xyz/search",
      "body": {
        "query": "${company} recent news funding announcements partnerships press releases"
      },
      "maxAmount": "0.10"
    }
  ]
}
