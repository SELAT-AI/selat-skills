{
  "skill_name": "token-price",
  "evals": [
    {
      "id": "trigger-eth",
      "prompt": "what's the price of ETH right now",
      "expected_output": "Runs token-price --symbols ETH and returns the spot price.",
      "assertions": ["token-price is selected", "Output includes an ETH USD price"]
    },
    {
      "id": "trigger-multi",
      "prompt": "spot prices for ETH, USDC and BTC",
      "expected_output": "Runs token-price with all three symbols.",
      "assertions": ["symbols includes ETH, USDC, BTC", "status 200"]
    },
    {
      "id": "trigger-casual",
      "prompt": "how much is bitcoin",
      "expected_output": "token-price with BTC.",
      "assertions": ["token-price is selected"]
    },
    {
      "id": "notrigger-holdings",
      "prompt": "what tokens does wallet 0xabc... hold",
      "expected_output": "Prefers wallet-holdings, not token-price.",
      "assertions": ["token-price is not selected"]
    },
    {
      "id": "notrigger-news",
      "prompt": "summarize the latest crypto news",
      "expected_output": "Skill does not trigger.",
      "assertions": ["token-price is not selected"]
    }
  ]
}
